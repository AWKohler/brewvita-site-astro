---
import MessagesWidget from "../components/MessagesWidget.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Brewvita Coffee Co. | Application</title>
        <link rel="icon" href="/favicon.ico" sizes="any" />
        <script src="https://cdn.tailwindcss.com" is:inline></script>
        <style is:global>
            @font-face {
                font-family: "Block Berthold Condensed";
                src: url("/Block_Berthold_Condensed.woff2") format("woff2");
                font-weight: 400 700;
                font-style: normal;
                font-display: swap;
            }
        </style>
        <link
            href="https://fonts.googleapis.com/css2?family=Alike&display=swap"
            rel="stylesheet"
        />
        <script is:inline>
            tailwind.config = {
                theme: {
                    extend: {
                        colors: {
                            ink: "#1f2327",
                            slate: "#2a3d52",
                            mist: "#b8cde6",
                            fog: "#d9e6f5",
                            navy: "#152433",
                            steel: "#2d4056",
                            alert: "#d93025",
                        },
                        fontFamily: {
                            sans: ['"Block Berthold Condensed"', "sans-serif"],
                            mono: ['"Alike"', "serif"],
                        },
                        boxShadow: {
                            hard: "4px 4px 0px 0px #152433",
                            "hard-hover": "2px 2px 0px 0px #152433",
                        },
                    },
                },
            };
        </script>
        <style is:global>
            .border-hard {
                border: 3px solid #152433;
            }
            .input-hard {
                border: 1.5px solid #152433;
                border-radius: 0.5rem;
            }

            .focus-effect:focus {
                background-color: #ffffff;
                box-shadow: 0 8px 16px rgba(31, 35, 39, 0.1);
                outline: 1.5px solid #152433;
                outline-offset: 2px;
            }

            .bg-grid {
                background-image:
                    linear-gradient(rgba(21, 36, 51, 0.1) 1px, transparent 1px),
                    linear-gradient(
                        90deg,
                        rgba(21, 36, 51, 0.1) 1px,
                        transparent 1px
                    );
                background-size: 20px 20px;
            }
        </style>
    </head>
    <body
        class="bg-fog text-navy font-sans antialiased min-h-screen flex flex-col"
    >
        <Navbar />

        <!-- Main Content -->
        <main
            class="flex-grow py-12 px-4 md:px-6 flex items-center justify-center"
        >
            <div class="w-full max-w-2xl">
                <!-- Form Container -->
                <div class="bg-white border-2 border-navy rounded-[2rem] shadow-lg relative">

                    <!-- Not Hiring Notice -->
                    <div class="bg-navy p-12 rounded-t-3xl relative overflow-hidden">
                        <div class="absolute top-0 right-0 p-4 opacity-10">
                            <svg
                                class="w-24 h-24 text-navy"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                                />
                            </svg>
                        </div>
                        <h1
                            class="text-3xl md:text-5xl font-bold uppercase text-fog mb-2 relative z-10"
                        >
                            Brewvita Involvement
                        </h1>
                        <p
                            class="font-mono text-mist font-bold tracking-wide relative z-10 text-sm md:text-base"
                        >
                            Apply to be involved with Brewvita
                        </p>
                    </div>
                    <div class="p-12 md:p-16 text-center flex flex-col items-center justify-center min-h-[300px]">
                        <div
                            class="w-16 h-16 bg-fog border-hard rounded-full flex items-center justify-center mb-6"
                        >
                            <svg class="w-8 h-8 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <h2 class="text-2xl md:text-3xl font-bold uppercase text-navy mb-4">
                            Not Currently Hiring
                        </h2>
                        <p class="font-mono text-sm text-slate max-w-md mx-auto mb-6">
                            Thank you for your interest in Brewvita! We are not currently accepting applications, but check back soon for future openings.
                        </p>
                        <a
                            href="/"
                            class="inline-block border-hard rounded-full bg-mist text-navy px-6 py-3 font-bold uppercase text-xs hover:bg-navy hover:text-white transition-colors shadow-hard hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none"
                        >
                            Return to Home
                        </a>
                    </div>
                </div>
            </div>
        </main>

        <Footer />

        <MessagesWidget />
    </body>
</html>
