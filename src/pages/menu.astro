---
import MessagesWidget from "../components/MessagesWidget.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Brewvita Coffee Co. | Menu</title>
        <link rel="icon" href="/favicon.ico" sizes="any" />
        <script src="https://cdn.tailwindcss.com" is:inline></script>
        <style is:global>
            @font-face {
                font-family: "Block Berthold Condensed";
                src: url("/Block_Berthold_Condensed.woff2") format("woff2");
                font-weight: 400 700;
                font-style: normal;
                font-display: swap;
            }
        </style>
        <link
            href="https://fonts.googleapis.com/css2?family=Alike&display=swap"
            rel="stylesheet"
        />
        <script is:inline>
            tailwind.config = {
                theme: {
                    extend: {
                        colors: {
                            ink: "#1f2327",
                            slate: "#2a3d52",
                            mist: "#b8cde6",
                            fog: "#d9e6f5",
                            navy: "#152433",
                            steel: "#2d4056",
                        },
                        fontFamily: {
                            sans: ['"Block Berthold Condensed"', "sans-serif"],
                            mono: ['"Alike"', "serif"],
                        },
                        boxShadow: {
                            hard: "4px 4px 0px 0px #152433",
                        },
                    },
                },
            };
        </script>
        <style is:global>
            .border-hard {
                border: 3px solid #152433;
            }
            .dotted-leader {
                background-image: linear-gradient(
                    to right,
                    #152433 33%,
                    rgba(255, 255, 255, 0) 0%
                );
                background-position: bottom;
                background-size: 6px 1px;
                background-repeat: repeat-x;
            }
            /* Hide scrollbar for clean look */
            .no-scrollbar::-webkit-scrollbar {
                display: none;
            }
            .no-scrollbar {
                -ms-overflow-style: none;
                scrollbar-width: none;
            }
        </style>
    </head>
    <body class="bg-fog text-navy font-sans antialiased">
        <Navbar />

        <!-- Menu Hero -->

        <!-- Receipt Style Menu -->
        <section class="py-16 px-4 md:px-6 max-w-4xl mx-auto">
            <div class="bg-white border-hard p-6 md:p-12 shadow-hard relative">
                <!-- Hole punch detail -->
                <div
                    class="absolute -top-4 left-1/2 -translate-x-1/2 w-6 h-6 md:w-8 md:h-8 rounded-full bg-fog border-hard"
                ></div>

                <div class="text-center mb-10">
                    <h2
                        class="text-3xl md:text-5xl font-bold uppercase border-b-4 border-double border-navy pb-4 inline-block px-8"
                    >
                        Full Menu
                    </h2>
                    <p class="font-mono text-xs uppercase mt-2 text-slate">
                        Prices vary by size (Sm / Med / Lg)
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-12">
                    <!-- Happy Love Month --> 
                         

                    <!-- Espresso Drinks -->
                    <div>
                        <h3
                            class="font-mono font-bold uppercase text-lg mb-4 text-navy border-b-2 border-navy inline-block"
                        >
                            Espresso Drinks
                        </h3>
                        <div class="space-y-4 font-mono text-sm uppercase">
                            <div class="flex items-end justify-between">
                                <span class="font-bold">Americano</span
                                ><span
                                    class="flex-1 mx-2 h-4 dotted-leader"
                                ></span
                                ><span>$4.50+</span>
                            </div>
                            <div class="flex items-end justify-between">
                                <span class="font-bold">Cappuccino</span
                                ><span
                                    class="flex-1 mx-2 h-4 dotted-leader"
                                ></span
                                ><span>$4.50+</span>
                            </div>
                            <div class="flex items-end justify-between">
                                <span class="font-bold">Caramel Macchiato</span
                                ><span
                                    class="flex-1 mx-2 h-4 dotted-leader"
                                ></span
                                ><span>$5.25+</span>
                            </div>
                            <div>
                                <div class="flex items-end justify-between">
                                    <span class="font-bold">Cortado</span
                                    ><span
                                        class="flex-1 mx-2 h-4 dotted-leader"
                                    ></span
                                    ><span>$5.50</span>
                                </div>
                                <p class="text-xs text-slate normal-case">
                                    8oz drink - 4 shots espresso/milk
                                </p>
                            </div>
                            <div class="flex items-end justify-between">
                                <span class="font-bold">Latte</span
                                ><span
                                    class="flex-1 mx-2 h-4 dotted-leader"
                                ></span
                                ><span>$4.50+</span>
                            </div>
                            <div class="flex items-end justify-between">
                                <span class="font-bold">Mocha</span
                                ><span
                                    class="flex-1 mx-2 h-4 dotted-leader"
                                ></span
                                ><span>$5.25+</span>
                            </div>
                            <div class="flex items-end justify-between">
                                <span class="font-bold">Cold Brew</span
                                ><span
                                    class="flex-1 mx-2 h-4 dotted-leader"
                                ></span
                                ><span>$5.00+</span>
                            </div>
                            <div>
                                <div class="flex items-end justify-between">
                                    <span class="font-bold">Frothy Coffee</span
                                    ><span
                                        class="flex-1 mx-2 h-4 dotted-leader"
                                    ></span
                                    ><span>$4.50+</span>
                                </div>
                                <p class="text-xs text-slate normal-case">
                                    Shaken Espresso
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Column 2 Wrapper -->
                    <div class="space-y-10">
                        <!-- Cold Brews -->
                        <div>
                            <h3
                                class="font-mono font-bold uppercase text-lg mb-4 text-navy border-b-2 border-navy inline-block"
                            >
                                Specialty Cold Brews
                            </h3>
                            <div class="space-y-4 font-mono text-sm uppercase">
                                <div class="flex items-end justify-between">
                                    <span class="font-bold">Salted Caramel</span
                                    ><span
                                        class="flex-1 mx-2 h-4 dotted-leader"
                                    ></span
                                    ><span>$6.90+</span>
                                </div>
                                <div>
                                    <div class="flex items-end justify-between">
                                        <span class="font-bold">Smooches</span
                                        ><span
                                            class="flex-1 mx-2 h-4 dotted-leader"
                                        ></span
                                        ><span>$6.90+</span>
                                    </div>
                                    <p class="text-xs text-slate normal-case">
                                        Strawberry Cold Foam
                                    </p>
                                </div>
                                <div>
                                    <div class="flex items-end justify-between">
                                        <span class="font-bold"
                                            >Raspberry Truffle</span
                                        ><span
                                            class="flex-1 mx-2 h-4 dotted-leader"
                                        ></span
                                        ><span>$6.90+</span>
                                    </div>
                                    <p class="text-xs text-slate normal-case">
                                        Raspberry Cold Foam
                                    </p>
                                </div>
                                <div>
                                    <div class="flex items-end justify-between">
                                        <span class="font-bold">Nutcracker</span
                                        ><span
                                            class="flex-1 mx-2 h-4 dotted-leader"
                                        ></span
                                        ><span>$6.90+</span>
                                    </div>
                                    <p class="text-xs text-slate normal-case">
                                        Toffee Nut & Salted Foam
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Not Coffee -->
                        <div>
                            <h3
                                class="font-mono font-bold uppercase text-lg mb-4 text-navy border-b-2 border-navy inline-block"
                            >
                                Not Coffee
                            </h3>
                            <div class="space-y-4 font-mono text-sm uppercase">
                                <div class="flex items-end justify-between">
                                    <span class="font-bold">Chai Latte</span
                                    ><span
                                        class="flex-1 mx-2 h-4 dotted-leader"
                                    ></span
                                    ><span>$4.50+</span>
                                </div>
                                <div class="flex items-end justify-between">
                                    <span class="font-bold">Matcha</span
                                    ><span
                                        class="flex-1 mx-2 h-4 dotted-leader"
                                    ></span
                                    ><span>$5.25+</span>
                                </div>
                                <div class="flex items-end justify-between">
                                    <span class="font-bold">Lemonade</span
                                    ><span
                                        class="flex-1 mx-2 h-4 dotted-leader"
                                    ></span
                                    ><span>$3.00+</span>
                                </div>
                                <div class="flex items-end justify-between">
                                    <span class="font-bold">Hot Chocolate</span
                                    ><span
                                        class="flex-1 mx-2 h-4 dotted-leader"
                                    ></span
                                    ><span>$3.75+</span>
                                </div>
                                <div class="flex items-end justify-between">
                                    <span class="font-bold">Iced Tea</span
                                    ><span
                                        class="flex-1 mx-2 h-4 dotted-leader"
                                    ></span
                                    ><span>$3.00+</span>
                                </div>
                            </div>
                        </div>

                        <!-- Coffee -->
                        <div>
                            <h3
                                class="font-mono font-bold uppercase text-lg mb-4 text-navy border-b-2 border-navy inline-block"
                            >
                                Classic
                            </h3>
                            <div class="space-y-4 font-mono text-sm uppercase">
                                <div class="flex items-end justify-between">
                                    <span class="font-bold">Hot Coffee</span
                                    ><span
                                        class="flex-1 mx-2 h-4 dotted-leader"
                                    ></span
                                    ><span>$3.00+</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div
                    class="mt-12 text-center pt-8 border-t-2 border-dashed border-navy/30"
                >
                    <img
                        src="https://bwipjs-api.metafloor.com/?bcid=code128&text=BREWVITA&scale=2&height=10&color=152433"
                        alt="Barcode"
                        class="mx-auto opacity-80 h-10 mb-2"
                    />
                    <p class="font-mono text-[10px] uppercase text-slate">
                        Thanks for supporting students
                    </p>
                </div>
            </div>
        </section>

        <Footer />
        <MessagesWidget />
    </body>
</html>
