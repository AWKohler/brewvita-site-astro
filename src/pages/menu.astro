---
import MessagesWidget from "../components/MessagesWidget.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

// Menu data structure - easily modifiable
const menuSections = [
  {
    title: "Espresso Drinks",
    items: [
      { name: "Americano", price: "$4.50+", note: null },
      { name: "Cappuccino", price: "$4.50+", note: null },
      { name: "Caramel Macchiato", price: "$5.25+", note: null },
      { name: "Cortado", price: "$5.50", note: "8oz drink - 4 shots espresso/milk" },
      { name: "Latte", price: "$4.50+", note: null },
      { name: "Mocha", price: "$5.25+", note: null },
      { name: "Cold Brew", price: "$5.00+", note: null },
      { name: "Frothy Coffee", price: "$4.50+", note: "shaken espresso" },
    ],
  },
    {
    title: "Lotus",
    items: [
      {
        name: "Strawberry Pina Colada",
        price: "$3.00+",
        note: "pink lotus with strawberry, coconut, and pineapple",
      },
      {
        name:"Ocean Mist", price:"$3.00+", note:"white lotus with coconut, blue raspberry, and apple"
      },
      { name: "Ellie Bear", price: "$3.00+", note: "white lotus with peach and strawberry" },
      { name: "Ring by Spring", price: "$3.00+", note: "pink lotus with kiwi and strawberry" },
      { name: "Black Bear", price: "$3.00+", note: "purple lotus with blackberry and blue raspberry" },
      { name: "Mother of the Dragon", price: "$3.00+", note: "pink lotus with dragon fruit" },
    ],
  },
  {
    title: "Specialty Cold Brews",
    items: [
      { name: "Salted Caramel", price: "$6.90+", note: "caramel cold brew topped with salted foam and caramel drizzle" },
      { name: "Smooches", price: "$6.90+", note: "cold brew with white mocha and vanilla topped with strawberry cold foam" },
      { name: "Raspberry Truffle", price: "$6.90+", note: "cold brew with white mocha and vanilla topped with raspberry cold foam" },
      { name: "Nutcracker", price: "$6.90+", note: "toffee nut cold brew with salted foam and caramel drizzle" },
    ],
  },
  {
    title: "Not Coffee",
    items: [
      { name: "Chai Latte", price: "$4.50+", note: null },
      { name: "Matcha", price: "$5.25+", note: null },
      { name: "Lemonade", price: "$3.00+", note: null },
      { name: "Hot Chocolate", price: "$3.75+", note: null },
      { name: "Iced Tea", price: "$3.00+", note: null },
    ],
  },
  {
    title: "Classic",
    items: [{ name: "Hot Coffee", price: "$3.00+", note: null }],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Brewvita Coffee Co. | Menu</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <script src="https://cdn.tailwindcss.com" is:inline></script>
    <style is:global>
      @font-face {
        font-family: "Block Berthold Condensed";
        src: url("/Block_Berthold_Condensed.woff2") format("woff2");
        font-weight: 400 700;
        font-style: normal;
        font-display: swap;
      }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Alike&display=swap" rel="stylesheet" />
    <script is:inline>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ink: "#1f2327",
              slate: "#2a3d52",
              mist: "#b8cde6",
              fog: "#d9e6f5",
              navy: "#152433",
              steel: "#2d4056",
            },
            fontFamily: {
              sans: ['"Block Berthold Condensed"', "sans-serif"],
              mono: ['"Alike"', "serif"],
            },
            boxShadow: {
              hard: "4px 4px 0px 0px #152433",
            },
          },
        },
      };
    </script>
    <style is:global>
      .border-hard {
        border: 3px solid #152433;
      }
      .dotted-leader {
        background-image: linear-gradient(to right, #152433 33%, rgba(255, 255, 255, 0) 0%);
        background-position: bottom;
        background-size: 6px 1px;
        background-repeat: repeat-x;
      }
      /* Hide scrollbar for clean look */
      .no-scrollbar::-webkit-scrollbar {
        display: none;
      }
      .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </head>
  <body class="bg-fog text-navy font-sans antialiased">
    <Navbar />

    <!-- Menu Hero -->

    <!-- Receipt Style Menu -->
    <section class="py-16 px-4 md:px-6 max-w-4xl mx-auto">
      <div class="bg-white border-hard p-6 md:p-12 shadow-hard relative">
        <!-- Hole punch detail -->
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 w-6 h-6 md:w-8 md:h-8 rounded-full bg-fog border-hard">
        </div>

        <div class="text-center mb-10">
          <h2
            class="text-3xl md:text-5xl font-bold uppercase border-b-4 border-double border-navy pb-4 inline-block px-8"
          >
            Menu
          </h2>
          <p class="font-mono text-xs uppercase mt-2 text-slate">Prices vary by size (Sm / Med / Lg)</p>
        </div>

        <div class="columns-1 md:columns-2 gap-x-8 [column-fill:balance]">
          {
            menuSections.map((section) => (
              <div class="h-fit mb-6 break-inside-avoid">
                <h3 class="font-mono font-bold uppercase text-lg mb-2 text-navy border-b-2 border-navy inline-block">
                  {section.title}
                </h3>
                <div class="space-y-1 font-mono text-sm uppercase">
                  {section.items.map((item) => (
                    <div class="break-inside-avoid">
                      <div class="flex items-end justify-between">
                        <span class="font-bold">{item.name}</span>
                        <span class="flex-1 mx-2 h-4 dotted-leader" />
                        <span>{item.price}</span>
                      </div>
                      {item.note && <p class="text-xs text-slate normal-case leading-tight">{item.note}</p>}
                    </div>
                  ))}
                </div>
              </div>
            ))
          }

          <div class="mt-12 text-center">
            <a
              href="/order"
              class="inline-block border-hard rounded-full bg-mist text-navy px-6 py-3 font-bold uppercase text-sm shadow-hard hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all hover:bg-navy hover:text-white"
            >
              Order Online
            </a>
          </div>
        </div>
      </div>

      <Footer />
      <MessagesWidget />
    </section>
  </body>
</html>

